{
  "extends": "./.svelte-kit/tsconfig.json",
  "compilerOptions": {
    "allowJs": true,
    "checkJs": true,
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "lib": ["dom.iterable"],
    "types": ["jest"]
  },
  "include": ["src/**/*.d.ts", "src/**/*.ts", "src/**/*.js", "tests/**/*.ts"]
}
